{
    "name": "Optimization GPU",
    "dockerComposeFile": "../docker-compose.yaml",
    "service": "jupyter-gpu",
    "workspaceFolder": "/app",
    "customizations": {
        "vscodium": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter"
            ]
        }
    },
    "remoteUser": "root",
    "updateRemoteUserUID": false,
    "containerUser": "root",
    "containerEnv": {
        "http_proxy": "${localEnv:http_proxy}",
        "https_proxy": "${localEnv:https_proxy}",
        "no_proxy": "${localEnv:no_proxy}"
    },
    "postCreateCommand": "chown -R root:root /app/unit_test /app/data /app/run"
}